rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isFinanceOwner() {
      return request.auth != null
        && request.auth.token.email == 'gu.correa98@gmail.com';
    }

    match /financePrivateExpenses/{expenseId} {
      allow read, write: if isFinanceOwner();
    }

    match /financeIntegrationSettings/{settingId} {
      allow read, write: if isFinanceOwner();
    }
  }
}
